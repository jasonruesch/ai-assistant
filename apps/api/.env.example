# Copy to .env for local development.
DATABASE_URL="postgresql://sourcesage:sourcesage@localhost:5432/sourcesage?schema=public"

# Anthropic API key — server-only, never shipped to the browser.
ANTHROPIC_API_KEY="sk-ant-..."

# Voyage AI key for embeddings (RAG). Claude has no embeddings endpoint, so the
# knowledge-base search uses Voyage by default. See src/lib/embeddings.ts.
VOYAGE_API_KEY="pa-..."

PORT=3000
HOST=0.0.0.0
# Set in production (Docker/Fly) to the absolute path of the built web client so
# the API serves the SPA from the same origin. Leave unset in dev (Vite serves).
# WEB_DIST="/app/apps/web/dist"
